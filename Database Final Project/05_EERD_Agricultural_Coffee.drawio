0" parent="155"><mxGeometry x="0.75" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell><mxCell id="158" value="&lt;b&gt;EERD Legend&lt;/b&gt;&lt;br&gt;─────────────────────&lt;br&gt;[PK]  Primary Key (bold underline)&lt;br&gt;[FK]  Foreign Key (italic)&lt;br&gt;[AK]  Alternate/Unique Key (underline)&lt;br&gt;[PK/FK] Composite PK that is also FK&lt;br&gt;(d, t) = Disjoint, Total specialisation&lt;br&gt;(d) = Disjoint  |  (t) = Total&lt;br&gt;N / 1 / 0..1 = Cardinality notation&lt;br&gt;⟨SUPERTYPE⟩ = Generalisation entity&lt;br&gt;⟨SUBTYPE⟩   = Specialised entity&lt;br&gt;⟨ASSOCIATIVE⟩ = M:N with own attributes&lt;br&gt;Double border = Associative / Weak entity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#888888;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=9;" vertex="1" parent="1"><mxGeometry x="20" y="20" width="270" height="280" as="geometry" /></mxCell><mxCell id="159" value="&lt;b&gt;Enhanced Entity-Relationship Diagram (EERD)&lt;/b&gt;&lt;br&gt;Ministry of Agriculture – Coffee Growers Management System (agri_coffee_db)&lt;br&gt;&lt;i&gt;12 entities · ISA hierarchy (Persons → Farmers | ExtensionWorkers) · Associative entity (FarmVarieties) · Disjoint total specialisation&lt;/i&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="300" y="1630" width="1600" height="60" as="geometry" /></mxCell></root></mxGraphModel>
